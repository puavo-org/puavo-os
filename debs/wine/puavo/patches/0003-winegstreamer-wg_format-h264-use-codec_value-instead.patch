From f6a78932cf9e137696e9bdff130e56293003065d Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Tuomas=20R=C3=A4s=C3=A4nen?= <tuomas.rasanen@opinsys.fi>
Date: Fri, 16 Feb 2024 15:01:30 +0200
Subject: [PATCH 3/4] winegstreamer/wg_format/h264: use "codec_value" instead
 of "streamheader"

---
 dlls/winegstreamer/wg_format.c | 7 ++++---
 1 file changed, 4 insertions(+), 3 deletions(-)

diff --git a/dlls/winegstreamer/wg_format.c b/dlls/winegstreamer/wg_format.c
index d4e0a457729..dbb8abb6fa1 100644
--- a/dlls/winegstreamer/wg_format.c
+++ b/dlls/winegstreamer/wg_format.c
@@ -487,8 +487,9 @@ static void wg_format_from_caps_video_h264(struct wg_format *format, const GstCa
     }
 
     codec_data_len = 0;
-    if ((codec_data_value = gst_structure_get_value(structure, "streamheader")) && (codec_data = gst_value_get_buffer(codec_data_value)))
+    if ((codec_data_value = gst_structure_get_value(structure, "codec_data")) && (codec_data = gst_value_get_buffer(codec_data_value)))
     {
+        GST_WARNING("Found \"codec_data\" value from %" GST_PTR_FORMAT ".", caps);
         gst_buffer_map(codec_data, &map, GST_MAP_READ);
         if (map.size <= sizeof(format->u.video_h264.codec_data))
         {
@@ -500,7 +501,7 @@ static void wg_format_from_caps_video_h264(struct wg_format *format, const GstCa
         gst_buffer_unmap(codec_data, &map);
     }
     else
-        GST_WARNING("Failed to get \"streamheader\" value from %" GST_PTR_FORMAT ".", caps);
+        GST_WARNING("Failed to get \"codec_data\" value from %" GST_PTR_FORMAT ".", caps);
 
     format->major_type = WG_MAJOR_TYPE_VIDEO_H264;
     format->u.video_h264.width = width;
@@ -867,7 +868,7 @@ static GstCaps *wg_format_to_caps_video_h264(const struct wg_format *format)
         GST_BUFFER_PTS(buffer) = 0;
         GST_BUFFER_DTS(buffer) = 0;
         gst_buffer_fill(buffer, 0, format->u.video_h264.codec_data, format->u.video_h264.codec_data_len);
-        gst_caps_set_simple(caps, "streamheader", GST_TYPE_BUFFER, buffer, NULL);
+        gst_caps_set_simple(caps, "codec_data", GST_TYPE_BUFFER, buffer, NULL);
         gst_buffer_unref(buffer);
     }
     gst_caps_set_simple(caps, "parsed", G_TYPE_BOOLEAN, TRUE, NULL);
-- 
